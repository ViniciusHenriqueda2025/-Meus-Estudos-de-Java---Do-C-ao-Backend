import java.util.Scanner;
public class Main {
	public static void main(String[] args) {

	Scanner sc = new Scanner(System.in);
	
	produto TV= new produto();
		TV.nome = "TV";
		TV.preco = 900.00;
		TV.quantidade = 10 ;	
		System.out.println ();
		
		System.out.println(TV);
		System.out.println ();
		
	System.out.print ("VAI ADICIONAR QUANTOS PRODUTOS ? = ");
	int quant = sc.nextInt();	
	 TV.quantidade += quant;
	 				
	System.out.println ();					
	System.out.println (TV);	
	System.out.println ();
	
	System.out.print ("VAI RETIRAR QUANTOS PRODUTOS ? = ");
	int quanti = sc.nextInt();	
	 TV.quantidade -= quanti;
	 						
	System.out.println ();							
	System.out.println(TV);									
								
	}
}

class produto{
    String nome;
    double preco;
    int quantidade;
    
    double precototal(){
    
    return   preco * quantidade ;
    
    }
    
    public String toString(){
     return "PRODUTO " + nome + " $ " + String.format("%.2f", preco ) + " , " + quantidade + " Units ,  TOTAL = " + String.format("%.2f", precototal() ); 
        
        
    }
    
    }
